# ============================================================================
#  Discord → Linear Triage Bot — environment template
# ============================================================================
#
#  Behaviour summary (see README.md for the full version):
#
#  Report path (allow-listed reporters in monitored channels):
#    - Classifier (Claude) returns strict JSON in ONE of these categories:
#        bug / feature / improvement / noise
#      plus needs_triage, is_new_issue, status_signal, area_labels,
#      mentioned_assignees.
#    - "noise" → drop. Everything else proceeds to a planning step.
#    - Labels applied to Linear are drawn from a FIXED allowlist:
#        BE   FE   UI   Bug   Feature   Improvement
#      The bot NEVER auto-creates labels. Labels outside the set are dropped.
#    - Create vs. update: one Discord message NEVER creates two tickets.
#        - Reply/follow-up to a previously-processed message with a stored
#          Linear issue id  →  comment on that issue (+ optional state
#          transition driven by status_signal).
#        - Otherwise, before creating, search by title — on a clear match
#          to an OPEN issue, comment on it instead of creating a duplicate.
#    - Status-by-TYPE transitions: status_signal maps resolved→completed,
#      in_progress→started, cannot_reproduce→canceled. The bot picks the
#      team's first state of the target TYPE (workspace-customisable names,
#      stable types).
#    - Assignee comes from mentioned_assignees[0], resolved via
#      DISCORD_LINEAR_MAP first, then by display-name match against team
#      members. needs_triage forces unassigned.
#    - REQUIRE_APPROVAL=true (default) routes the planned action through a
#      ✅/❌ embed in the approval channel; =false executes immediately and
#      posts a confirmation there.
#
#  Query mode (anyone — read-only):
#    - Ask in the dedicated QUERY_CHANNEL_ID (no @-mention needed — every human
#      message is treated as a potential question), or @-mention the bot in a
#      monitored channel. If QUERY_CHANNEL_ID is unset, @-mention the bot in the
#      approval channel (fallback). A
#      lightweight LLM call (parse_query) decides is_query + a SOURCE scope
#      (discord | linear | both), then routes:
#        * source=discord -> the local Discord path: resolve the person and scan
#                            their recent activity in MONITORED channels (last
#                            QUERY_DISCORD_LOOKBACK_DAYS days); a model writes ONE
#                            concise summary. Linear is not touched.
#        * source=linear|both -> the TOOL-DRIVEN query engine (query_engine.py):
#                            the bot's own Claude call is handed READ-ONLY Linear
#                            tools and answers OPEN-ENDED questions with NO handler
#                            per phrasing — status, status-change history, due
#                            dates, priority/estimate/cycle, sub-issues, sorted
#                            lists, "what changed". Tools:
#                              - search_issues  (full-text: title+description+comments)
#                              - get_issue      (full fields incl. dueDate/estimate/cycle/parent/children)
#                              - get_issue_history (state/assignee/priority change timeline)
#                              - list_issues    (assignee/labels/state/dates/priority + sort)
#                              - resolve_member / list_team_members
#                              - source_message_for_issue / tracked_issue_for_message (linking)
#                            The loop is CAPPED at 5 tool iterations, then answers
#                            with what it has.
#    - DISCORD <-> LINEAR LINKING: the bot stores a message->issue mapping for
#      every issue it files/updates; the engine reads it both ways ("which discord
#      message is behind NFT2-591", or as a reply "is this already tracked?") and
#      replies with the issue AND the Discord jump link together. LIMITATION:
#      stored links exist ONLY for issues the bot itself created/updated; for a
#      manually-filed issue it says so plainly (no heuristic guessing).
#    - EDITED MESSAGES re-trigger QUERY MODE ONLY (never the report path):
#      editing an @-mention question re-answers on the new text with a fresh
#      reply; editing an ordinary message does nothing (no second ticket).
#    - DISCORD_LINEAR_MAP cross-links a person's Discord and Linear identities so
#      the discord-scoped path lines up both sides reliably (see below).
#    - Query mode (and edit-handling) runs BEFORE the report path and NEVER
#      creates, comments on, or modifies any Linear issue — read-only throughout.
#
# ============================================================================

# --- Discord ---------------------------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Three distinct channel roles — keep them separate:
#   - MONITORED: report/triage. Allow-listed reporters' messages here get
#     classified into Linear tickets.
#   - APPROVAL: ✅/❌ only. Approval embeds are posted and reactions handled here.
#     Nothing else happens here.
#   - QUERY: ask/answer only. Questions are asked and answered here; no ticket
#     creation, no approvals.

# Comma-separated Discord channel IDs to monitor for incoming reports.
# The QUERY_CHANNEL_ID must NOT be one of these (it's query-only).
MONITORED_CHANNEL_IDS=

# Channel where the bot posts approval embeds and handles ✅/❌ (private
# staff-only channel). ONLY approvals happen here — it no longer answers queries.
APPROVAL_CHANNEL_ID=

# Dedicated channel for asking the bot questions (read-only query mode). In this
# channel the @-mention requirement is DROPPED — every non-bot human message is
# treated as a potential query and answered here. No ticket creation, no
# approvals. Leave empty to fall back to the previous behaviour: queries answered
# via @-mention in the APPROVAL_CHANNEL_ID. (Queries via @-mention in monitored
# channels keep working either way.)
QUERY_CHANNEL_ID=

# --- Reporter allowlist ----------------------------------------------------
# Only messages from these users get classified. IDs take priority over names.
# Leave both empty to disable triage (the bot will warn and act on nobody).

# Comma-separated Discord user IDs (numeric snowflakes).
ALLOWED_REPORTER_IDS=

# Comma-separated Discord display names (case-insensitive). Used as a fallback
# when a reporter's Discord ID is not yet known. Default: Sid,Harsh,Trishi.
ALLOWED_REPORTER_NAMES=Sid,Harsh,Trishi

# --- Discord ↔ Linear identity map -----------------------------------------
# JSON object mapping Discord user ID (string) → Linear user email or UUID.
# Used to assign / @-mention the reporter on the created Linear issue.
# Must be a valid JSON object; invalid JSON logs a warning and falls back to {}.
# Example: {"123456789":"sid@membrane.social","987654321":"harsh@nfthing.com"}
DISCORD_LINEAR_MAP={}

# --- Classifier (Anthropic) ------------------------------------------------
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-sonnet-4-6

# --- Linear ----------------------------------------------------------------
LINEAR_API_KEY=
# UUID of the target Linear team (NFThing2.0).
LINEAR_TEAM_ID=

# --- Tuning ----------------------------------------------------------------
# Skip messages shorter than this (no attachments). Cuts classifier cost.
MIN_MESSAGE_LENGTH=20

# Drop classifier verdicts below this confidence (0.0–1.0).
MIN_CONFIDENCE=0.6

# Seconds to wait before classifying, so follow-ups (frontend vs backend,
# "nvm my mistake", etc.) can join the same thread context. 0 disables.
CLASSIFY_DELAY_SECONDS=0

# SQLite state file path.
DB_PATH=./bot_state.db

# --- Query mode (person-centric lookups) -----------------------------------
# For "what is <person> working on?" queries that combine Linear assignments
# with recent Discord activity. Both optional.

# How many days back to scan monitored channels for a person's Discord activity.
QUERY_DISCORD_LOOKBACK_DAYS=14

# Hard cap on messages scanned per monitored channel per query (bounds cost).
QUERY_MAX_MESSAGES_PER_CHANNEL=400

# --- Standup notes (read-only context for QUERY MODE only) -----------------
# A separate rclone process syncs Gemini standup notes from Google Drive into a
# LOCAL folder; the bot only READS local files and holds NO Google credential.
# Standup data is NEVER an input to ticket creation.
#
# Local folder rclone syncs the "Notes by Gemini" docs into. Empty/unset →
# standup features no-op gracefully (query mode just won't have standup context).
STANDUP_DIR=
# Optional shell command to force a sync before reading, used ONLY when a question
# is clearly about a recent/today standup (e.g. "what did we decide this morning").
# Empty → the bot reads whatever rclone has already synced to STANDUP_DIR.
# Example: STANDUP_SYNC_CMD=rclone copy gdrive:Standups ./standups --drive-export-formats docx
STANDUP_SYNC_CMD=

# --- Archive snapshot (read-only query-mode fallback) ----------------------
# A FROZEN local markdown file of past Done issues. When live Linear can't return
# an issue (archived / not found), query mode falls back to this snapshot — and
# labels every such answer "(from archive snapshot, through <date>)". NEVER an
# input to ticket creation. Empty → archive features no-op.
ARCHIVE_FILE=
# Example: ARCHIVE_FILE=./NFThing2_0_Consolidated_Done_Issues_Archive.md

# --- Holiday / leave channel (read-only context) ---------------------------
# Discord channel id where people post OOO / on-leave notes. Read-only context for
# query mode ("why was X delayed"). This channel is NOT monitored for triage and
# never produces a ticket. 0/unset → disabled.
HOLIDAY_CHANNEL_ID=

# --- Approval flow ---------------------------------------------------------
# Require human ✅ before creating the Linear issue. Accepts true/false/1/0/yes/no.
# Set to false for auto-create (no approval embed, no reaction step).
REQUIRE_APPROVAL=true

# --- Logging ---------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
